{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-offer-starter.dev/schemas/validation.schema.json",
  "title": "ValidationPlan",
  "type": "object",
  "required": ["hypothesis", "method", "successSignal", "safetyRules"],
  "properties": {
    "hypothesis": { "type": "string", "minLength": 10 },
    "method": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "successSignal": { "type": "string", "minLength": 3 },
    "customerConversations": { "type": "number", "minimum": 0 },
    "paidPilots": { "type": "number", "minimum": 0 },
    "safetyRules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "additionalProperties": false
}
