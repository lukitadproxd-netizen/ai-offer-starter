{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-offer-starter.dev/schemas/delivery.schema.json",
  "title": "DeliveryChecklist",
  "type": "object",
  "required": ["offerName", "deliverables", "qualityChecks", "handoffAssets", "supportWindowDays"],
  "properties": {
    "offerName": { "type": "string", "minLength": 3 },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "qualityChecks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "handoffAssets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "supportWindowDays": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
