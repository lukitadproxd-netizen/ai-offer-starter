{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-offer-starter.dev/schemas/offer.schema.json",
  "title": "Offer",
  "type": "object",
  "required": ["name", "customer", "problem", "outcome", "deliverables", "price", "delivery"],
  "properties": {
    "name": { "type": "string", "minLength": 3 },
    "customer": { "type": "string", "minLength": 3 },
    "problem": { "type": "string", "minLength": 3 },
    "outcome": { "type": "string", "minLength": 3 },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "price": {
      "type": "object",
      "required": ["setupFee"],
      "properties": {
        "currency": { "type": "string", "default": "USD" },
        "setupFee": { "type": "number", "minimum": 0 },
        "monthlyFee": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "delivery": { "type": "string", "minLength": 3 },
    "exclusions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "claims": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
